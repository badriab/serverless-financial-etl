# ============================================================
# serverless-financial-etl — environment variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it is in .gitignore
# In production, all secrets are stored in AWS Secrets Manager
# ============================================================

# ----------------------------------------------------------
# Alpha Vantage API (https://www.alphavantage.co — free key)
# Used by: lambdas/ingestor/handler.py (local dev only)
# Production: stored in Secrets Manager as etl/alpha-vantage
# ----------------------------------------------------------
ALPHA_VANTAGE_API_KEY=your_api_key_here

# ----------------------------------------------------------
# Pipeline configuration
# ----------------------------------------------------------
TARGET_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA
AWS_REGION=ap-south-1

# ----------------------------------------------------------
# S3 buckets (created by CDK — check CloudFormation outputs)
# ----------------------------------------------------------
RAW_BUCKET=etl-raw-YOUR_ACCOUNT_ID-ap-south-1
PROCESSED_BUCKET=etl-processed-YOUR_ACCOUNT_ID-ap-south-1

# ----------------------------------------------------------
# Secrets Manager secret names (created by CDK)
# ----------------------------------------------------------
ALPHA_VANTAGE_SECRET=etl/alpha-vantage
DB_SECRET_NAME=etl/rds-credentials

# ----------------------------------------------------------
# Alerts
# ----------------------------------------------------------
ALERT_EMAIL=your@email.com

# ----------------------------------------------------------
# CDK deployment (used by infrastructure/app.py)
# ----------------------------------------------------------
CDK_DEFAULT_ACCOUNT=YOUR_AWS_ACCOUNT_ID
CDK_DEFAULT_REGION=ap-south-1
